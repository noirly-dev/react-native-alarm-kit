{
  "name": "@noirly-dev/react-native-alarm-kit",
  "version": "0.1.3",
  "description": "Local-only native scheduling engine for alarms, tasks, and reminders in React Native",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native.config.js",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build",
    "test": "jest",
    "example": "yarn --cwd example",
    "bootstrap:example": "bash scripts/bootstrap-example.sh",
    "codegen:check": "bash scripts/generate-codegen-artifacts.sh"
  },
  "keywords": [
    "react-native",
    "alarm",
    "reminder",
    "scheduler",
    "turbo-module",
    "new-architecture"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/noirly-dev/react-native-alarm-kit.git"
  },
  "author": "Noirly",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/noirly-dev/react-native-alarm-kit/issues"
  },
  "homepage": "https://github.com/noirly-dev/react-native-alarm-kit#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "codegenConfig": {
    "name": "NativeAlarmKitSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.noirly.alarmkit"
    }
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@react-native/babel-preset": "^0.76.5",
    "@react-native/eslint-config": "^0.76.5",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "eslint": "^8.57.1",
    "eslint-plugin-tsdoc": "^0.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-builder-bob": "^0.35.2",
    "tsd": "^0.31.2",
    "typescript": "^5.7.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
